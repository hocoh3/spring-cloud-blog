<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.blog.admin.mapper.AdminMapper">

    <select id="selectByUsername" parameterType="java.lang.String" resultType="com.blog.admin.entity.Admin">
        select * from admin where username = #{username} and deleted = 0
    </select>

</mapper>
